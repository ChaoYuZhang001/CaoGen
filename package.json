    "release:mac:preflight:arm64": "node scripts/macos-release-preflight.mjs --arch arm64",
    "dist:mac:release:x64": "npm run release:mac:preflight:x64 && npm run build && npm run prepare:native-build && npm run prepare:mac-binaries && electron-builder --config electron-builder.release.cjs --mac --x64 && npm run test:macos-release-audit:required -- --arch x64 && npm run test:packaged-app:mac:x64",
    "dist:mac:release:arm64": "npm run release:mac:preflight:arm64 && npm run build && npm run prepare:native-build && npm run prepare:mac-binaries && electron-builder --config electron-builder.release.cjs --mac --arm64 && npm run test:macos-release-audit:required -- --arch arm64 && npm run test:packaged-app:mac:arm64",
